BASE_OBJECTS = registration.o r_api.o
STAGED_OBJECTS = @RSD_OBJECTS@
OBJECTS = $(BASE_OBJECTS)

# -I../tools/lib   makes simd_dispatch.h and cpu_features.h available to src/
# -I../tools/kernels makes kernel_api.h available to src/ and tools/lib/
PKG_CPPFLAGS = -I../tools/kernels -I../tools/lib @RSD_SIMDE_CPPFLAGS@
PKG_LIBS = $(STAGED_OBJECTS)

all: $(SHLIB)

clean:
	rm -f $(SHLIB) $(BASE_OBJECTS) symbols.rds
